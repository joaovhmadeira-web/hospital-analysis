# ============================================================
# Configurações de Banco de Dados
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env!
# ============================================================

# Opção 1 — URL completa (ex.: Supabase, Railway, Render, etc.)
# Se definida, tem prioridade sobre as variáveis individuais abaixo.
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_banco

# Opção 2 — Variáveis individuais (fallback se DATABASE_URL não estiver definida)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_NAME=hospital_indicadores
